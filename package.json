{
  "name": "devstack-cli",
  "version": "0.1.0",
  "description": "CLI to scaffold production-ready NestJS applications with best practices, linting, swagger, and project automation",
  "keywords": [
    "cli",
    "devstack",
    "nestjs",
    "scaffold",
    "typescript",
    "nodejs",
    "backend",
    "generator"
  ],
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "type": "commonjs",
  "bin": {
    "devstack": "./bin/devstack.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "engines": {
    "node": ">=16"
  },
  "repository": "https://github.com/kaustubhgawade/devstack-cli.git",
  "author": "Kaustubh Gawade <kaustubhgawade2602@gmail.com>",
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc",
    "dev": "yarn build && devstack",
    "start": "node dist/cli.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,json}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "chalk": "5.6.2",
    "commander": "14.0.3",
    "ejs": "5.0.2",
    "fs-extra": "11.3.4",
    "inquirer": "13.4.2",
    "nestjs-pino": "^4.6.1",
    "ora": "9.4.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "25.6.0",
    "eslint": "10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "husky": "9.1.7",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2"
  }
}
