{
  "name": "devstack-cli",
  "version": "1.0.0",
  "description": "CLI to scaffold production-ready NestJS applications with best practices, linting, swagger, and project automation",
  "keywords": [
    "cli",
    "devstack",
    "nestjs",
    "scaffold",
    "typescript",
    "nodejs",
    "backend",
    "generator"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "commonjs",
  "bin": {
    "devstack": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=16"
  },
  "repository": "https://github.com/kaustubhgawade/devstack-cli.git",
  "author": "Kaustubh Gawade <kaustubhgawade2602@gmail.com>",
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "25.6.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
}
